# Database
DATABASE_URL=
LOCAL_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/fbx

# Secrets
ADMIN_TOKEN=change-me
CONGRESS_API_KEY=

# CORS
CORS_ORIGINS=http://localhost:3000

# Models
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
