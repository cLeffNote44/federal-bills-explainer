# ===========================================
# Federal Bills Explainer — Environment Config
# ===========================================
# Copy to .env.local and fill in your values

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Database (Drizzle) ---
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# --- AI Providers ---
# "claude" (production) or "ollama" (local dev)
AI_PROVIDER=claude

# Claude API (required if AI_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-...

# Ollama (required if AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# OpenAI (required for embeddings regardless of AI_PROVIDER)
OPENAI_API_KEY=sk-...

# --- Congress.gov API ---
CONGRESS_API_KEY=your-congress-api-key

# --- Vercel Cron ---
CRON_SECRET=your-cron-secret

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
