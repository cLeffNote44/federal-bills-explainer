HF_HOME=

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Mode
DRY_RUN=true
EMBEDDINGS_ENABLED=false
EXPLANATIONS_ENABLED=false

# Ingestion controls
INGEST_LIMIT=
INGEST_SINCE=
