{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "cd apps/frontend && pnpm install && pnpm build",
  "outputDirectory": "apps/frontend/.next",
  "installCommand": "pnpm install",
  "framework": "nextjs",
  "regions": ["iad1"],
  "build": {
    "env": {
      "NEXT_PUBLIC_API_BASE_URL": "@api_base_url"
    }
  },
  "git": {
    "deploymentEnabled": {
      "main": true,
      "claude/*": false
    }
  }
}
