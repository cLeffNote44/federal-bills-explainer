# Local dev
LOCAL_DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/fbx
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/fbx

# API
ADMIN_TOKEN=change-me
CORS_ORIGINS=http://localhost:3000

# Models
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EXPLAIN_MODEL=microsoft/phi-3-mini-4k-instruct
HF_HOME=/github/home/.cache/huggingface

# Provider
CONGRESS_API_KEY=

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Feature flags
EMBEDDINGS_ENABLED=false
EXPLANATIONS_ENABLED=false

# Ingestion controls
INGEST_LIMIT=
INGEST_SINCE=

